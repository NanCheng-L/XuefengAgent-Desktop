{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XuefengAgent-Desktop",
  "version": "0.1.1",
  "identifier": "com.xuefeng.agent-desktop",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/NanCheng-L/XuefengAgent-Desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDM0IxNDI0QjgxMEVGQjkKUldTNTd4QzRKQlE3bkVqUWE4VkhZWlhOZnRITlQ3N1J5cFVrZDUySFZhTE1YSjRVZ3ptRDRqSzcK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "雪峰Agent - AI高考志愿顾问",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}